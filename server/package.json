{
  "name": "windarms-server",
  "version": "1.0.0",
  "private": true,
  "description": "WindArms.io authoritative multiplayer server — rooms, matchmaking, movement validation (Phase 3).",
  "main": "dist/server/src/index.js",
  "scripts": {
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/server/src/index.js",
    "typecheck": "tsc --noEmit",
    "test": "tsx --test src/tests/combat.test.ts src/tests/validation.test.ts src/tests/progression.test.ts src/tests/streaks.test.ts src/tests/lagcomp.test.ts",
    "prisma:generate": "prisma generate",
    "prisma:push": "prisma db push",
    "prisma:studio": "prisma studio"
  },
  "dependencies": {
    "@prisma/client": "5.22.0",
    "bcryptjs": "2.4.3",
    "cors": "2.8.5",
    "dotenv": "16.4.5",
    "express": "4.21.2",
    "jsonwebtoken": "9.0.2",
    "socket.io": "4.8.1"
  },
  "devDependencies": {
    "@types/bcryptjs": "2.4.6",
    "@types/cors": "2.8.17",
    "@types/express": "4.17.21",
    "@types/jsonwebtoken": "9.0.7",
    "@types/node": "22.9.0",
    "prisma": "5.22.0",
    "tsx": "4.19.2",
    "typescript": "5.6.3"
  },
  "engines": {
    "node": ">=18.18.0"
  }
}
