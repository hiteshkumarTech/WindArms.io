# ── Client (Next.js) ─────────────────────────────────────────────
# Multiplayer server URL. Copy this file to .env.local for overrides.
# Defaults to http://localhost:4000 when unset.
NEXT_PUBLIC_WS_URL=http://localhost:4000

# ── Server (server/) ─────────────────────────────────────────────
# Set these as real environment variables when deploying (Railway/Render
# inject PORT automatically). They are not auto-loaded from this file.
# PORT=4000
# CLIENT_ORIGIN=http://localhost:3000
