# ── Client (Next.js) ─────────────────────────────────────────────
# Multiplayer server URL. Copy this file to .env.local for overrides.
# Defaults to http://localhost:4000 when unset.
NEXT_PUBLIC_WS_URL=http://localhost:4000

# ── Server (server/.env — loaded automatically via dotenv) ────────
# PORT=4000
# CLIENT_ORIGIN=http://localhost:3000

# Accounts / XP / leaderboard (optional — guests work without it).
# Free serverless Postgres: https://neon.tech → create project → copy the
# connection string. Local Postgres works too.
# DATABASE_URL=postgresql://user:password@host/dbname?sslmode=require

# Any long random string. REQUIRED in production if accounts are enabled.
# JWT_SECRET=change-me-to-a-long-random-string
